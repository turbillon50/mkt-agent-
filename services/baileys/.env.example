# --- Bridge ---
PORT=3001
WHATSAPP_BRIDGE_SECRET=

# Webhook al cual reenviar mensajes entrantes (Goossip /api/whatsapp/inbound)
GOOSSIP_INBOUND_WEBHOOK=https://goossip.vercel.app/api/whatsapp/inbound

# Directorio donde Baileys guarda la auth (multi-file). Si lo borras, hay que
# volver a escanear el QR.
SESSION_DIR=./sessions

LOG_LEVEL=info
