# --- OpenRouter (chat / generation) --------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings (memoria semántica) -------------------------------------
# Used to embed posts/knowledge/mentions into pgvector. Defaults to OpenAI
# text-embedding-3-small (1536 dims). If you set OPENAI_BASE_URL you can
# route through another provider.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Neon Postgres + pgvector --------------------------------------------
# Get this from https://console.neon.tech (use the pooled/serverless URL)
DATABASE_URL=

# --- Brand / persona ------------------------------------------------------
BRAND_NAME=My Brand
BRAND_VOICE=friendly, concise, expert
BRAND_TOPICS=marketing,automation,ai
BRAND_LANGUAGE=en

# --- Schedule (cron) ------------------------------------------------------
POST_CRON=0 9,18 * * *
PLAN_CRON=0 8 * * 1
TIMEZONE=UTC

# --- Twitter / X ----------------------------------------------------------
TWITTER_ENABLED=false
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn -------------------------------------------------------------
LINKEDIN_ENABLED=false
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Memory tuning --------------------------------------------------------
MEMORY_RECALL_K=5
MEMORY_MIN_SIMILARITY=0.78

# --- Clerk (dashboard auth) ----------------------------------------------
# Get from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Vercel Cron ----------------------------------------------------------
# Any random string; Vercel sends it in Authorization: Bearer <secret>
CRON_SECRET=
