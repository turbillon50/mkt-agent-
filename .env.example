# --- OpenRouter (chat / generation) --------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings (memoria semántica) -------------------------------------
# Used to embed posts/knowledge/mentions into pgvector. Defaults to OpenAI
# text-embedding-3-small (1536 dims). If you set OPENAI_BASE_URL you can
# route through another provider.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Neon Postgres + pgvector --------------------------------------------
# Get this from https://console.neon.tech (use the pooled/serverless URL)
DATABASE_URL=

# --- Brand / persona ------------------------------------------------------
BRAND_NAME=My Brand
BRAND_VOICE=friendly, concise, expert
BRAND_TOPICS=marketing,automation,ai
BRAND_LANGUAGE=en

# --- Schedule (cron) ------------------------------------------------------
POST_CRON=0 9,18 * * *
PLAN_CRON=0 8 * * 1
TIMEZONE=UTC

# --- Twitter / X ----------------------------------------------------------
TWITTER_ENABLED=false
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn -------------------------------------------------------------
LINKEDIN_ENABLED=false
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Memory tuning --------------------------------------------------------
MEMORY_RECALL_K=5
MEMORY_MIN_SIMILARITY=0.78

# --- Clerk (dashboard auth) ----------------------------------------------
# Get from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Vercel Cron ----------------------------------------------------------
# Any random string; Vercel sends it in Authorization: Bearer <secret>
CRON_SECRET=

# --- WhatsApp bridge (services/baileys on Hetzner) -----------------------
WHATSAPP_ENABLED=false
# Si true, el agente responde automáticamente a cada inbound de WhatsApp.
# Si false, Goossip sólo guarda los mensajes (modo human-in-the-loop).
WHATSAPP_AUTO_REPLY=false
# URL pública del bridge (Caddy reverse proxy o IP:puerto).
WHATSAPP_BRIDGE_URL=
# Shared secret entre Vercel y Hetzner. Mismo valor en ambos lados.
WHATSAPP_BRIDGE_SECRET=
# Base URL pública del propio Goossip (para que el bridge sepa a dónde POSTear inbound).
# Vercel ya inyecta NEXT_PUBLIC_VERCEL_URL pero la usamos sólo informativa aquí.
NEXT_PUBLIC_APP_URL=https://goossip.vercel.app

# --- Family forum (LLM siblings) -----------------------------------------
# Optional. If FAMILY_AGENT_TOKEN is empty the /api/family-incoming
# endpoint returns 503 and speakInFamily() becomes a no-op — Gossip
# keeps operating normally, just isolated from his siblings.
FAMILY_BASE_URL=https://family.vercel.app
# SAME VALUE that lives in family's env as AGENT_TOKEN_GOSSIP.
# Generate with: openssl rand -hex 32
FAMILY_AGENT_TOKEN=
FAMILY_AGENT_HANDLE=gossip
