# --- OpenRouter (LLM) -----------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Brand / persona ------------------------------------------------------
BRAND_NAME=My Brand
BRAND_VOICE=friendly, concise, expert
BRAND_TOPICS=marketing,automation,ai
BRAND_LANGUAGE=en

# --- Schedule (cron) ------------------------------------------------------
# Default: every day at 09:00 and 18:00, server time.
POST_CRON=0 9,18 * * *
PLAN_CRON=0 8 * * 1
TIMEZONE=UTC

# --- Twitter / X ----------------------------------------------------------
TWITTER_ENABLED=false
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn -------------------------------------------------------------
LINKEDIN_ENABLED=false
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Persistence ----------------------------------------------------------
DATA_DIR=./data
